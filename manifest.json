{
  "manifest_version": 3,
  "name": "Lecture Checkpoint Quiz",
  "version": "2.0",
  "description": "Transcribes course videos locally with Whisper and generates AI quiz questions every 10 minutes to promote active recall",

  "permissions": [
    "storage",
    "tabCapture",
    "offscreen",
    "activeTab",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://huggingface.co/*",
    "https://*.huggingface.co/*",
    "https://*.hf.co/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/books_48pt_3x.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["sidebar.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
